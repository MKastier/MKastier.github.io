---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Tu vytvoríme taký pekný, na stred zarovnaný blok -->
    <main class="min-h-screen bg-slate-900 text-white flex flex-col items-center justify-center">
        
        <h1 class="text-5xl font-extrabold text-blue-400 mb-6">
            Ahoj, ja som Miro 👋
        </h1>
        
        <p class="text-xl text-slate-300 max-w-lg text-center">
            Vitaj na mojom novom portfóliu. Práve sa hrám s Tailwind CSS a zatiaľ to vyzerá super!
        </p>

        <button class="mt-8 px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-bold rounded-xl transition-all">
            Moje projekty
        </button>

    </main>
</Layout>
