---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- HOME -->
    <section id="home" class="max-w-6xl mx-auto px-6 py-24 md:py-32 flex flex-col items-start min-h-screen">
        <p class="text-[#0f766e] font-bold tracking-wide uppercase mb-3">
            Hi, my name is
        </p>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-6 tracking-tight">
            Majro. <br />
            <span class="text-gray-400">I build things for the web.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mb-10 leading-relaxed">
            I'm a software developer specializing in building (and occasionally designing) exceptional digital experiences. Currently, I'm focused on building modern web applications.
        </p>
        <a href="#projects" class="px-8 py-4 bg-gray-900 hover:bg-black text-white font-semibold rounded-lg transition-all shadow-md hover:shadow-xl">
            Check out my projects
        </a>
    </section>

    <!-- ABOUT -->
    <section id="about" class="w-full bg-gray-50 py-24 min-h-screen border-t border-gray-100">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">About Me</h2>
            <p class="text-gray-600">Nothing to write about me</p>
        </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="w-full bg-white py-24 min-h-screen border-t border-gray-100">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">My Projects</h2>
            <p class="text-gray-600">In process...</p>
        </div>
    </section>

	    <!-- SKILLS -->
    <section id="skills" class="relative w-full py-24 min-h-screen flex justify-center items-center bg-gradient-to-br from-teal-100/80 via-teal-50 to-[#dff2ee]">
        
        <div class="max-w-4xl mx-auto px-6 w-full flex flex-col items-center relative z-10">
            
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-black text-slate-800 mb-4 tracking-tight">My Skills</h2>
                <p class="text-slate-500 max-w-md mx-auto text-lg">
                    Technologies and tools I work with to bring ideas to life.
                </p>
            </div>

            <div class="w-full flex flex-col gap-6">

                <div class="skill-card group relative bg-white/40 backdrop-blur-xl border border-white/60 rounded-3xl overflow-hidden transition-all duration-300 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-xl hover:border-white/80 cursor-pointer">
                    
                    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[#0f766e] rounded-full filter blur-[100px] opacity-0 group-hover:opacity-10 transition-opacity duration-700 pointer-events-none z-0"></div>
                    
                    <div class="skill-header flex items-center justify-between p-6 md:p-8 relative z-10">
                        <div class="flex items-center gap-5">
                            <div class="w-14 h-14 bg-white/70 rounded-2xl flex items-center justify-center text-[#0f766e] border border-white/50 shadow-sm">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-800 tracking-wide">Frontend</h3>
                        </div>
                        <div class="chevron text-slate-400 transition-transform duration-300">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>

                    <div class="skill-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out relative z-10">
                        <div class="overflow-hidden">
                            <div class="p-6 md:p-8 pt-0 border-t border-white/60 mt-2 flex flex-wrap gap-3">
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-orange-500"></span>HTML5</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-500"></span>CSS3</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-yellow-400"></span>JavaScript</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-cyan-400"></span>React</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-sky-500"></span>Tailwind CSS</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="skill-card group relative bg-white/40 backdrop-blur-xl border border-white/60 rounded-3xl overflow-hidden transition-all duration-300 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-xl hover:border-white/80 cursor-pointer">
                    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[#0f766e] rounded-full filter blur-[100px] opacity-0 group-hover:opacity-10 transition-opacity duration-700 pointer-events-none z-0"></div>
                    
                    <div class="skill-header flex items-center justify-between p-6 md:p-8 relative z-10">
                        <div class="flex items-center gap-5">
                            <div class="w-14 h-14 bg-white/70 rounded-2xl flex items-center justify-center text-[#0f766e] border border-white/50 shadow-sm">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-800 tracking-wide">Backend</h3>
                        </div>
                        <div class="chevron text-slate-400 transition-transform duration-300">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>

                    <div class="skill-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out relative z-10">
                        <div class="overflow-hidden">
                            <div class="p-6 md:p-8 pt-0 border-t border-white/60 mt-2 flex flex-wrap gap-3">
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span>Node.js</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-400"></span>PostgreSQL</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-[#0f766e]"></span>Supabase</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="skill-card group relative bg-white/40 backdrop-blur-xl border border-white/60 rounded-3xl overflow-hidden transition-all duration-300 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-xl hover:border-white/80 cursor-pointer">
                    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[#0f766e] rounded-full filter blur-[100px] opacity-0 group-hover:opacity-10 transition-opacity duration-700 pointer-events-none z-0"></div>
                    
                    <div class="skill-header flex items-center justify-between p-6 md:p-8 relative z-10">
                        <div class="flex items-center gap-5">
                            <div class="w-14 h-14 bg-white/70 rounded-2xl flex items-center justify-center text-[#0f766e] border border-white/50 shadow-sm">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-800 tracking-wide">Design & Tools</h3>
                        </div>
                        <div class="chevron text-slate-400 transition-transform duration-300">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>

                    <div class="skill-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out relative z-10">
                        <div class="overflow-hidden">
                            <div class="p-6 md:p-8 pt-0 border-t border-white/60 mt-2 flex flex-wrap gap-3">
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-purple-500"></span>Figma</div>
                                <div class="px-4 py-2 bg-white/60 border border-white/50 shadow-sm rounded-xl text-slate-700 font-medium flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-orange-600"></span>Git & GitHub</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

<!-- CONTACT -->
    <section id="contact" class="relative w-full py-24 min-h-screen flex justify-center items-center overflow-hidden bg-teal-50">
        
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[150%] md:w-[120%] h-[150%] bg-gradient-to-br from-[#0f766e] to-teal-200 rounded-[100%] filter blur-[150px] opacity-30"></div>

        <div class="max-w-4xl mx-auto px-6 w-full flex flex-col items-center relative z-10">
            
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Get In Touch</h2>
                <p class="text-slate-700 max-w-md mx-auto text-lg">
                    My inbox is always open. Whether you have a question or just want to say hi, I'll try my best to get back to you!
                </p>
            </div>

            <div class="w-full max-w-lg bg-white/40 backdrop-blur-2xl rounded-3xl shadow-xl p-8 md:p-10 border border-white/60">
                
                <form id="contact-form" class="flex flex-col gap-6">
                    
                    <input type="hidden" name="access_key" value="60a11a4c-0475-4e69-805a-295f21f2c550">
                    
                    <div>
                        <label for="name" class="block text-sm font-bold text-slate-800 mb-2">Name</label>
                        <input type="text" id="name" name="name" placeholder="Enter your name" required
                            class="w-full px-4 py-3 bg-white/60 border border-white/50 rounded-xl text-slate-900 placeholder-slate-500 focus:outline-none focus:border-[#0f766e] focus:bg-white transition-all shadow-sm">
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-bold text-slate-800 mb-2">E-mail</label>
                        <input type="email" id="email" name="email" placeholder="Enter your email" required
                            class="w-full px-4 py-3 bg-white/60 border border-white/50 rounded-xl text-slate-900 placeholder-slate-500 focus:outline-none focus:border-[#0f766e] focus:bg-white transition-all shadow-sm">
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-bold text-slate-800 mb-2">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="Hi, I'd like to talk about..." required
                            class="w-full px-4 py-3 bg-white/60 border border-white/50 rounded-xl text-slate-900 placeholder-slate-500 focus:outline-none focus:border-[#0f766e] focus:bg-white transition-all resize-none shadow-sm"></textarea>
                    </div>

                    <div class="mt-2">
                        <button id="submit-btn" type="submit"
                            class="w-full py-4 bg-[#0f766e] hover:bg-[#0b5c56] text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-[#0f766e]/40 transform hover:-translate-y-1">
                            Send Message
                        </button>
                    </div>
                </form>
            </div>
        </div>

		<div id="result-popup" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
            <div id="popup-card" class="bg-white rounded-3xl shadow-2xl p-8 max-w-sm w-full mx-6 transform scale-95 transition-transform duration-300 text-center">
                
                <div id="popup-icon-success" class="hidden w-16 h-16 mx-auto bg-teal-100 text-[#0f766e] rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>

                <div id="popup-icon-error" class="hidden w-16 h-16 mx-auto bg-red-100 text-red-500 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                </div>
                
                <h3 id="popup-title" class="text-2xl font-black text-slate-900 mb-2">Title</h3>
                <p id="popup-message" class="text-slate-600 mb-8 font-medium">Message goes here.</p>
                
                <button id="close-popup" class="w-full py-3 bg-slate-100 hover:bg-slate-200 text-slate-800 font-bold rounded-xl transition-all">
                    Close
                </button>
            </div>
        </div>
    </section>

	<script is:inline>

		const form = document.getElementById('contact-form');
		const submitBtn = form?.querySelector('button[type="submit"]');
		
		const popup = document.getElementById('result-popup');
		const popupCard = document.getElementById('popup-card');
		const closePopupBtn = document.getElementById('close-popup');
		const popupTitle = document.getElementById('popup-title');
		const popupMessage = document.getElementById('popup-message');
		const iconSuccess = document.getElementById('popup-icon-success');
		const iconError = document.getElementById('popup-icon-error');
	
		if (form) {
			form.addEventListener('submit', async function(e) {
				e.preventDefault();
	
				const originalBtnText = submitBtn.innerText;
				submitBtn.innerText = 'Sending...';
				submitBtn.disabled = true;
	
				const formData = new FormData(form);
	
				try {
					const response = await fetch('https://api.web3forms.com/submit', {
						method: 'POST',
						headers: {
							'Accept': 'application/json'
						},
						body: formData
					});
	
					const data = await response.json();
	
					if (response.status === 200) {
						showPopup('Message Sent!', 'Thank you for reaching out. I will get back to you as soon as possible.', true);
						form.reset();
					} else {
						showPopup('Oops!', data.message || 'Something went wrong. Please try again later.', false);
					}
				} catch (error) {
					showPopup('Error', 'Unable to send message. Please check your internet connection.', false);
				} finally {
					submitBtn.innerText = originalBtnText;
					submitBtn.disabled = false;
				}
			});
		}
	
		function showPopup(title, message, isSuccess) {
			popupTitle.innerText = title;
			popupMessage.innerText = message;
			
			if (isSuccess) {
				iconSuccess.classList.remove('hidden');
				iconError.classList.add('hidden');
			} else {
				iconSuccess.classList.add('hidden');
				iconError.classList.remove('hidden');
			}
	
			popup.classList.remove('opacity-0', 'pointer-events-none');
			popupCard.classList.remove('scale-95');
			popupCard.classList.add('scale-100');
		}
	
		if (closePopupBtn) {
			closePopupBtn.addEventListener('click', () => {
				popup.classList.add('opacity-0', 'pointer-events-none');
				popupCard.classList.remove('scale-100');
				popupCard.classList.add('scale-95');
			});
		}

		// --- LOGIKA PRE SKILLS (VYROLOVANIE) ---
        const skillCards = document.querySelectorAll('.skill-card');
        
        skillCards.forEach(card => {
            const header = card.querySelector('.skill-header');
            const content = card.querySelector('.skill-content');
            const chevron = card.querySelector('.chevron');

            header.addEventListener('click', () => {
                // Zistíme, či je karta momentálne otvorená
                const isOpen = content.classList.contains('grid-rows-[1fr]');

                if (isOpen) {
                    // Ak je otvorená, ZATVOR JU
                    content.classList.remove('grid-rows-[1fr]', 'opacity-100');
                    content.classList.add('grid-rows-[0fr]', 'opacity-0');
                    chevron.classList.remove('rotate-180');
                    card.classList.remove('border-[#0f766e]'); // zrušíme zelený okraj
                } else {
                    // Ak je zatvorená, OTVOR JU
                    content.classList.remove('grid-rows-[0fr]', 'opacity-0');
                    content.classList.add('grid-rows-[1fr]', 'opacity-100');
                    chevron.classList.add('rotate-180');
                    card.classList.add('border-[#0f766e]'); // zasvieti zelený okraj
                }
            });
        });
	</script>
</Layout>


