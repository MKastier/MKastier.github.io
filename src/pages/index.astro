---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Sekcia Hero (Úvod) -->
    <section class="max-w-6xl mx-auto px-6 py-24 md:py-32 flex flex-col items-start">
        
        <p class="text-[#0f766e] font-bold tracking-wide uppercase mb-3">
            Hi, my name is
        </p>

        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-6 tracking-tight">
            Majro <br />
            <span class="text-gray-400">I build things for the web.</span>
        </h1>
        
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mb-10 leading-relaxed">
            I'm a software developer specializing in building (and occasionally designing) exceptional digital experiences. Currently, I'm focused on building modern web applications.
        </p>

        <a href="#projects" class="px-8 py-4 bg-gray-900 hover:bg-black text-white font-semibold rounded-lg transition-all shadow-md hover:shadow-xl">
            Check out my projects
        </a>

    </section>
</Layout>
