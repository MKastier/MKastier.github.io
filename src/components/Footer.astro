---
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-white border-t border-gray-100 mt-20">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-center gap-4">
    
    <p class="text-gray-500 text-sm">
      © {currentYear} Miroslav. All rights reserved.
    </p>

    <div class="flex gap-6">
        <a href="https://github.com/MKastier" target="_blank">
          <iconify-icon
            width="50"
            height="50"
            icon="mdi:github"
            class="text-gray-600 hover:text-teal-700 transition-all duration-300">
        </iconify-icon>
        </a>
      
        <a href="https://www.linkedin.com/in/miroslav-ka%C5%A1tier-788a92310/" target="_blank">
          <iconify-icon
            width="50"
            height="50"
            icon="mdi:linkedin"
            class="text-gray-600 hover:text-teal-700 transition-all duration-300">
        </iconify-icon>
        </a>

        <a href="https://www.instagram.com/miroslavkastier/" target="_blank">
            <iconify-icon
              width="50"
              height="50"
              icon="mdi:instagram"
              class="text-gray-600 hover:text-teal-700 transition-all duration-300">
          </iconify-icon>
          </a>
      </div>

  </div>
</footer>